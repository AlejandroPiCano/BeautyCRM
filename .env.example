# ─── Database (CubePath VPS — PostgreSQL) ────────────────────────────────────
# Format: postgresql://USER:PASSWORD@YOUR_CUBEPATH_IP:5432/DATABASE_NAME
DATABASE_URL="postgresql://crm_user:your_password@YOUR_CUBEPATH_IP:5432/beautycrm"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ─── OAuth Providers (optional) ───────────────────────────────────────────────
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── n8n Webhook (CubePath VPS) ─────────────────────────────────────────────
# URL del webhook de n8n para notificaciones de citas
# En desarrollo local:
# N8N_WEBHOOK_URL="http://localhost:5678/webhook/cita-creada"
# En producción (CubePath VPS):
# N8N_WEBHOOK_URL="http://TU_IP_CUBEPATH:5678/webhook/cita-creada"
# Con dominio y SSL:
# N8N_WEBHOOK_URL="https://n8n.tu-dominio.com/webhook/cita-creada"
N8N_WEBHOOK_URL=""

# ─── Internal API Key ────────────────────────────────────────────────────────
# API key for internal services (n8n) to access protected endpoints
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=""

# ─── OpenRouter (Chatbot IA del Dashboard) ────────────────────────────────────
# Obtén tu clave en https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-..."
# Modelos gratuitos disponibles (sufijo :free = sin coste):
#   google/gemini-2.0-flash-exp:free
#   meta-llama/llama-3.3-70b-instruct:free
#   mistralai/mistral-7b-instruct:free
#   qwen/qwen-2-7b-instruct:free
OPENROUTER_MODEL="google/gemini-2.0-flash-exp:free"

# ─── OpenAI (Análisis Fotográfico IA) ───────────────────────────────────────
# Obtén tu clave en https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
# Modelo con soporte de visión (el más económico con visión)
# gpt-4o-mini  ← recomendado ($0.15/M tokens entrada)
# gpt-4o       ← mayor calidad, más caro
OPENAI_VISION_MODEL="gpt-4o-mini"
